# 서버 설정
PORT=3000
NODE_ENV=development

# PostgreSQL (Render.com)
DATABASE_URL=postgresql://user:password@host:5432/everest_pos

# JWT 인증
JWT_SECRET=your_jwt_secret_here_change_this
JWT_EXPIRES_IN=24h

# 외부 시스템 API (기존 앱들)
INVENTORY_API_URL=https://everest-inventory.onrender.com
MEMBERSHIP_API_URL=https://everest-ocr.onrender.com
REVENUE_API_URL=https://everest-finance.onrender.com

# 내부 API Key (서버 간 통신)
INTERNAL_API_KEY=your_internal_api_key_here

# T-Order Channel API Key (T-Order 기사가 입력)
TORDER_CHANNEL_API_KEY=

# NICE VAN 카드결제 API
NICE_API_KEY=
NICE_API_SECRET=
NICE_MID=

# SMS (발주 알림 - 재고관리에서 사용)
SMS_API_KEY=
